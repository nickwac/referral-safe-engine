{
  "info": {
    "_postman_id": "8b5d0d3c-3d31-4f4c-a95b-2f26dd74f001",
    "name": "Cycle-Safe Referral Engine API",
    "description": "Postman collection for the Cycle-Safe Referral Engine backend. Login or refresh first to populate the `access_token` collection variable. Cookie-based refresh/session routes rely on Postman's cookie jar after login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "access_token", "value": "" },
    { "key": "admin_email", "value": "admin@example.com" },
    { "key": "admin_password", "value": "admin123" },
    { "key": "super_admin_email", "value": "owner@example.com" },
    { "key": "super_admin_password", "value": "Owner123!" },
    { "key": "user_id", "value": "00000000-0000-0000-0000-000000000000" },
    { "key": "member_id", "value": "00000000-0000-0000-0000-000000000000" },
    { "key": "session_id", "value": "00000000-0000-0000-0000-000000000000" },
    { "key": "org_id", "value": "00000000-0000-0000-0000-000000000001" },
    { "key": "claim_child_id", "value": "00000000-0000-0000-0000-000000000000" },
    { "key": "claim_parent_id", "value": "00000000-0000-0000-0000-000000000000" }
  ],
  "item": [
    {
      "name": "Health",
      "auth": { "type": "noauth" },
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/login (Org Admin)",
          "auth": { "type": "noauth" },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) { pm.collectionVariables.set('access_token', json.access_token); }",
                  "if (json.org_id) { pm.collectionVariables.set('org_id', json.org_id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "POST /auth/login (Super Admin)",
          "auth": { "type": "noauth" },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) { pm.collectionVariables.set('access_token', json.access_token); }",
                  "if (json.org_id) { pm.collectionVariables.set('org_id', json.org_id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{super_admin_email}}\",\n  \"password\": \"{{super_admin_password}}\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "POST /auth/refresh",
          "auth": { "type": "noauth" },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) { pm.collectionVariables.set('access_token', json.access_token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/auth/refresh", "host": ["{{base_url}}"], "path": ["auth", "refresh"] }
          }
        },
        {
          "name": "POST /auth/logout",
